# Whisper Model Configuration
# Options: tiny, base, small, medium, large
# Larger models = better accuracy but slower + more RAM
WHISPER_MODEL=base

# Text Cleanup Method
# Options: basic, ollama, claude, openai
# basic = free, simple punctuation
# ollama = free, requires local Ollama installation
# claude = paid (~$0.001/cleanup), best quality
# openai = paid (~$0.002/cleanup), good quality
CLEANUP_METHOD=basic

# API Keys (optional, only needed for respective cleanup methods)
CLAUDE_API_KEY=your_claude_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# Ollama Configuration (if using local LLM)
OLLAMA_URL=http://localhost:11434
